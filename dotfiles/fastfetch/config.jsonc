      "key": "в”” в””пҖұ",
      "keyColor": "blue",
      "text": "awk -F= '/^font=/ {gsub(/:size$/,\"\",$2); f=$2; s=$3} END {cmd=\"fc-match \\\"\" f \"\\\" -f %{style}\"; cmd | getline style; close(cmd); print f \" (\" s+0 \"pt, \" style \")\"}' /home/mindset/.config/foot/foot.ini",
    },
