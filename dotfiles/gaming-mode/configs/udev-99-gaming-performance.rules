# CPU performance governor
ACTION=="add", SUBSYSTEM=="cpu", KERNEL=="cpu[0-9]*", RUN+="/usr/bin/sh -c 'echo performance > /sys/devices/system/cpu/%k/cpufreq/scaling_governor'"

# NVIDIA runtime PM disable
ACTION=="add", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{power/control}="on"

# AMD GPU performance
ACTION=="add", SUBSYSTEM=="drm", KERNEL=="card[0-9]*", ATTR{device/power_dpm_force_performance_level}="high"
